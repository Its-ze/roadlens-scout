{
  "name": "roadlens-scout",
  "version": "0.1.13",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "powershell -NoProfile -ExecutionPolicy Bypass -File ../scripts/sync-app-firmware.ps1",
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "cap:sync": "cap sync android",
    "apk": "npm run build && cap sync android && cd android && gradlew.bat assembleDebug",
    "test:smart-targets": "tsc src/smartTargets.ts --target ES2022 --module ES2022 --moduleResolution bundler --outDir .smart-target-test --skipLibCheck && node tests/smartTargets.test.mjs"
  },
  "dependencies": {
    "@capacitor-community/bluetooth-le": "^8.2.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/share": "^8.0.1",
    "leaflet": "^1.9.4",
    "lucide": "^1.21.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@types/leaflet": "^1.9.21",
    "typescript": "^5.9.3",
    "vite": "^8.0.16"
  }
}
